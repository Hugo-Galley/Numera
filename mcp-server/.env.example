# ─── Serveur MCP — Suivi Budget ─────────────────────────────────
# Chemin vers la base de données SQLite
MCP_DB_PATH=/data/suivi_budget.db

# Nom du serveur MCP (affiché dans les clients)
MCP_SERVER_NAME=Suivi Budget MCP

# Transport : stdio | streamable-http | sse
MCP_TRANSPORT=stdio

# Host et port (uniquement pour streamable-http et sse)
MCP_HOST=0.0.0.0
MCP_PORT=8100
